HTTP_ADDR=:8080
HTTP_SHUTDOWN_TIMEOUT=30s

# Generate jwt_secret with: openssl rand -base64 32 
JWT_SECRET=
JWT_TTL=24h

TZ=Europe/Moscow

LOGGER_LEVEL=debug
LOGGER_FOLDER=out/logs

POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
DATABASE_URL=
# DATABASE_URL example postgres://POSTGRES_USER_VALUE:POSTGRES_PASSWORD_VALUE@(localhost or messenger-postgres):5432/POSTGRES_DB_VALUE?sslmode=disable