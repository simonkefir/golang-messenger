        "/users/{id}": {
            "get": {
                "description": "Получить пользователя в системе по ID",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "users"
                ],
                "summary": "Получить пользователя",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "ID получаемого пользователя",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Успешно полученный пользователь",
                        "schema": {
                            "$ref": "#/definitions/internal_feature_users_transport_http.UserDTOResponse"
                        }
                    },
                    "400": {
                        "description": "Invalid input",
                        "schema": {
                            "$ref": "#/definitions/github_com_simonkefir_golang-messenger_internal_core_transport_http_response.ErrorResponse"
                        }
                    },
                    "404": {
                        "description": "Not found",
                        "schema": {
                            "$ref": "#/definitions/github_com_simonkefir_golang-messenger_internal_core_transport_http_response.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "schema": {
                            "$ref": "#/definitions/github_com_simonkefir_golang-messenger_internal_core_transport_http_response.ErrorResponse"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "github_com_simonkefir_golang-messenger_internal_core_transport_http_response.ErrorResponse": {
            "type": "object",
            "properties": {
                "error": {
                    "type": "string"
                },
                "message": {
                    "type": "string"
                }
            }
        },
        "internal_feature_users_transport_http.CreateUserDTO": {
            "type": "object",
            "required": [
                "email",
                "password",
                "username"
            ],
            "properties": {
                "email": {
                    "type": "string",
                    "example": "alex@mail.com"
                },
                "password": {
                    "type": "string",
                    "minLength": 8,
                    "example": "wasd1234"
                },
                "username": {
                    "type": "string",
                    "maxLength": 40,
                    "minLength": 3,
                    "example": "alex"
                }
            }
        },
        "internal_feature_users_transport_http.LoginResponse": {
            "type": "object",
            "properties": {
                "token": {
                    "type": "string",
                    "example": "eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOjEsImV4cCI6NDEwMjQ0NDgwMH0.c36q-l2h78e5VqZQ3tZPbMZXZupO4g3M8hnudYMbdOE"
                }
            }
        },
        "internal_feature_users_transport_http.LoginUserDTO": {
            "type": "object",
            "required": [
                "email",
                "password"
            ],
            "properties": {
                "email": {
                    "type": "string",
                    "example": "alex@mail.com"
                },
                "password": {
                    "type": "string",
                    "minLength": 8,
                    "example": "wasd1234"
                }
            }
        },
        "internal_feature_users_transport_http.PatchUserDTO": {
            "type": "object",
            "properties": {
                "password": {
                    "type": "string",
                    "minLength": 8,
                    "example": "wasd1212"
                },
                "username": {
                    "type": "string",
                    "maxLength": 40,
                    "minLength": 3,
                    "example": "alexg"
                }
            }
        },
        "internal_feature_users_transport_http.UserDTOResponse": {
            "type": "object",
            "properties": {
                "created_at": {
                    "type": "string",
                    "example": "2006-01-02 15:04:05"
                },
                "email": {
                    "type": "string",
                    "example": "alex@mail.com"
                },
                "id": {
                    "type": "integer",
                    "example": 1
                },
                "username": {
                    "type": "string",
                    "example": "alex"
                }
            }
        }
    },
    "securityDefinitions": {
        "BearerAuth": {
            "description": "Используйте \"Bearer \u003cваш JWT-токен\u003e\"",
            "type": "apiKey",
            "name": "Authorization",
            "in": "header"
        }
    }
}